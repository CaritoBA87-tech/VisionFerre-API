{
  "providers": ["dotnet"],
  "setup": {
    "pkgs": ["dotnet-sdk_8"]
  },
  "variables": {
    "NIXPACKS_DOTNET_SDK_VERSION": "8",
    "ASPNETCORE_ENVIRONMENT": "Development"
  },
  "build": {
    "cmds": [
      "dotnet publish ./AulaDiser.Proyecto.API/AulaDiser.Proyecto.API.csproj -c Release -o out --self-contained false"
    ]
  }
}